public class Main {
    public static void main(String[] args) {
        int number = 10;

        if (number == 10) {
            System.out.println("They are equal. \n");
        }

        int age = 17;

        if (age >= 18) {
            System.out.println("You can vote! ");
            System.out.println("Please put an X in the ballot!");
        } else {
            if (18 - age == 1) {
                System.out.println("You can't vote! \n Please come back in " + (18 - age) + " year");
            } else {
                System.out.println("You can't vote! \n Please come back in " + (18 - age) + " years");
            }
        }
    }
}
