        System.out.println(Num1 + Num2);
        System.out.println(Num1 - Num2);
        System.out.println(Num1 * Num2);
        System.out.println(Num1 / Num2);

        double Numb1 = 5;
        int Numb2 = 3;

        System.out.println("D = " + (Numb1 + Numb2));
        System.out.println("D = " + (Numb1 - Numb2));
        System.out.println("D = " + Numb1 * Numb2);
        System.out.println("D = " + Numb1 / Numb2);
        System.out.println("D = " + Numb1 % Numb2);

        int myNum = 0;

        myNum += 4;
        System.out.println(myNum);

        myNum -= 4;
        System.out.println(myNum);

        myNum *= 4;
        System.out.println(myNum);

        myNum /= 4;
        System.out.println(myNum);

        myNum %= 4;
        System.out.println(myNum);

        myNum = 0;
        System.out.println(myNum++);
