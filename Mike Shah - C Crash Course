---------For Loop------
int	main()
{
	int	array[5];
	array[0] = 23;
	array[1] = 0;
	array[2] = -7;
	array[3] = 45;
	array[4] = 76;
	
	for (int i = 0; i < 5; i = i + 1) //i++
	{
		printf("array[%d]= %d\n", i, array[i]);
	}
	
	return (0);
}
--------While Loops-------
int	main()
{
	int	countdown = 10;
	while (countdown > 0){
		printf("%d\n", countdown);
		countdown = countdown -1;//countdown--
	}
	
	return (0);
}
