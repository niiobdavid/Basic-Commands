---------Recursions--------
#include <stdio.h>

void	countdown(int n)
{
	//base case- when the function returns (no more recursive calls)
	if (n < 0)
	{
		return;
	}
	printf("%d\n", n);
	return countdown(n -1);// recursive case - Calling the function again, solving a smaller problem
}
int	main()
{
	countdown(10);
	return (0);
}
