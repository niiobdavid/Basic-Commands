#include <stdio.h>

void	countdown(unsigned int n)
{
	//base case- when the function returns (no more recursive calls)
	if (n < 0)
	{
		return;
	}
	printf("%d\n", n);
	return countdown(n -1);// recursive case - Calling the function again, 
	//solving a smaller problem
}
int	main()
{
	countdown(-10);
	return (0);
}
//-10 when treated as unsigned int, will actually rep a positive number.
//If recursed too many times, then we get a 'stack overflow'.
