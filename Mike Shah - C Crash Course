-------------Pass by value Semantics in C-----------

#include <stdio.h>
#include <stdlib.h>

//Pass by value = makes copies of variables when passed into functions
void	SetValue(int new_value)
{
	new_value = 9999;
}

int	main()
{
	int x;

	x = 42;
	SetValue(x);
	printf("x is: %d\n", x);
//x was passed into the function so it replaced new_value, 
//thus it'll print 42
	
	return (0);
}
#include <stdio.h>
#include <stdlib.h>

void	SetValue(int* new_value)
{
	*new_value = 9999;
}

int	main()
{
	int x;

	x = 42;
	SetValue(&x);
	printf("x is: %d\n", x);
//it'll print 9999

	return (0);
}
