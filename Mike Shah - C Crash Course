int	main()
{
	int x = 42;
	printf("the address of x is: %p\n", &x);

	//Creating a pointer
	int* px = &x;
	int* px2 = &x;
	printf("px is: %p\n", px);
	printf("px2 is: %p\n", px2);

	//Accessing the value, tho the thing we point to
	printf("*px, the thing we point to is %d\n", *px);
	printf("*px2, the thing we point to is %d\n", *px2);

	//notice that both px and px2 point to the same address of x,
	//and both *px and *px2 point to the number stored in x.
	return (0);
}
